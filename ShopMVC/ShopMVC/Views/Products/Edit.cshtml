@model ShopMVC.Models.Product

@{
    ViewData["Title"] = "Edit Product";
}

<h2>Edit Product</h2>

<form method="post" action="/Products/Edit/@Model.Id">
    <input type="hidden" name="Id" value="@Model.Id" />
    <div class="mb-3">
        <label>Name</label>
        <input name="Name" value="@Model.Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Price</label>
        <input name="Price" value="@Model.Price" type="number" step="0.01" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Stock</label>
        <input name="Stock" value="@Model.Stock" type="number" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Category</label>
        <input name="Category" value="@Model.Category" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/Products" class="btn btn-secondary">Cancel</a>
</form>
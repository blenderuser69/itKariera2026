@model List<ShopMVC.Models.Order>
@{
    ViewData["Title"] = "Orders";
}

<h2>Orders</h2>
<a href="/Orders/Create" class="btn btn-primary mb-3">+ New Order</a>

@if (Model.Count == 0)
{
    <p>No orders yet.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Customer</th>
                <th>Date</th>
                <th>Status</th>
                <th>Total</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.Id</td>
                    <td>@order.CustomerName</td>
                    <td>@order.OrderDate.ToString("dd.MM.yyyy")</td>
                    <td>
                        @{
                            string badgeClass = "bg-warning text-dark";

                            if (order.Status == "Completed")
                            {
                                badgeClass = "bg-success";
                            }
                            else if (order.Status == "Cancelled")
                            {
                                badgeClass = "bg-danger";
                            }
                        }
                        <span class="badge @badgeClass">@order.Status</span>
                    </td>
                    <td>@order.Items.Sum(i => i.UnitPrice * i.Quantity).ToString("F2")$</td>
                    <td>
                        @if (Context.Session.GetString("IsLoggedIn") == "true")
                        {
                            <form method="post" action="/Orders/UpdateStatus/@order.Id" class="d-inline">
                                <select name="newStatus" class="form-select form-select-sm d-inline w-auto">
                                    <option>Pending</option>
                                    <option>Completed</option>
                                    <option>Cancelled</option>
                                </select>
                                <button type="submit" class="btn btn-sm btn-outline-primary">Update</button>
                            </form>
                            <a href="/Orders/Delete/@order.Id" class="btn btn-danger btn-sm ms-1">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}